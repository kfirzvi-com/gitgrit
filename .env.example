# GitGrit air-gapped deployment — environment variables.
#
# Copy to `.env` and fill in. Used by docker-compose.full.yaml.
# Cloud / Kamal deployments do NOT use this file.

# ── Image tag (set to the version baked into your bundle) ────────────────
TAG=1.0

# ── Public hostname & ports ─────────────────────────────────────────────
# Must be the hostname your internal GitLab can reach for webhook callbacks.
# Anything in {localhost, 127.0.0.1, 0.0.0.0, ::1, ""} is rejected by
# `python manage.py airgap_setup`.
# ALLOWED_HOSTS is derived from SITE_URL's hostname automatically — no need
# to set it separately.
SITE_URL=https://gitgrit.acme.internal
APP_PORT=3000

# ── Django secrets ──────────────────────────────────────────────────────
# Generate fresh values once per deployment and NEVER rotate them after
# stored OAuth tokens exist — rotation invalidates ciphertext at rest.
#
#   SECRET_KEY:
#     cat /dev/urandom | LC_ALL=C tr -dc 'a-zA-Z0-9' | fold -w 50 | head -n 1
#   GITGRIT_ENCRYPTION_KEY:
#     python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=
GITGRIT_ENCRYPTION_KEY=

# ── Database ────────────────────────────────────────────────────────────
POSTGRES_USER=gitgrit
POSTGRES_DB=gitgrit
POSTGRES_PASSWORD=

# ── Auth providers ──────────────────────────────────────────────────────
# Defaults for air-gap: only GitLab on. Flip Google/GitHub on only if your
# network has egress to accounts.google.com / github.com.
# Values must be the exact strings "True" or "False".
AUTH_PROVIDER_GITHUB_ENABLED=False
AUTH_PROVIDER_GITLAB_ENABLED=True
AUTH_PROVIDER_GOOGLE_ENABLED=False

# ── Self-hosted GitLab OAuth ────────────────────────────────────────────
# GITLAB_URL is the root of your GitLab instance (no trailing slash).
# Create an OAuth application there with callback
# {SITE_URL}/accounts/gitlab/login/callback/ and paste the credentials.
GITLAB_URL=https://gitlab.acme.internal
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# ── Sandbox network & DNS ───────────────────────────────────────────────
# Internal DNS resolver (comma-separated). gVisor cannot use Docker's
# embedded DNS, so the sandbox needs a real resolver it can reach.
SANDBOX_DNS=10.0.0.53,10.0.0.54

# ── Operator TLS chain ──────────────────────────────────────────────────
# Host path to a PEM file containing the CA chain that signed your internal
# GitLab's TLS cert (NOT the server cert itself). If your network has a
# TLS-intercepting proxy, append its CA to the same file.
# Mounted read-only into both the app container and any sandbox containers
# it spawns, at /etc/ssl/certs/custom-ca.pem.
GITGRIT_CUSTOM_CA_FILE_PATH=/opt/gitgrit/ca-bundle.pem
