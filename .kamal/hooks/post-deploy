#!/usr/bin/env bash
set -e

KAMAL="${KAMAL:-$(command -v kamal || echo /opt/homebrew/lib/ruby/gems/4.0.0/bin/kamal)}"

args=()
[ -n "$KAMAL_DESTINATION" ] && args+=("-d" "$KAMAL_DESTINATION")

echo "Building sandbox image on server..."
"$KAMAL" server exec "${args[@]}" "cd /tmp && docker exec \$(docker ps -q --filter label=service=gitgrit --filter label=role=web -l) tar -cf - -C /app sandbox_image | tar -xf - && docker build -t gitgrit-sandbox:latest /tmp/sandbox_image && rm -rf /tmp/sandbox_image"
